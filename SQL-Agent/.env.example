# SQL Agent Environment Variables
# Copy this file to .env and fill in the values

# LLM Provider (ollama, groq, or gemini)
MODEL_PROVIDER=ollama

# Ollama (Local LLM)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# Groq (Fast Cloud LLM) - Alternative
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_your_key_here

# Google Gemini (Alternative)
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=AIza_your_key_here

# Database (Same as Backend)
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/db?sslmode=require

# LangSmith (Optional - for debugging)
LANGSMITH_API_KEY=lsv2_your_key_here

# Feature Flags
SCHEMA_CACHE=0
ENABLE_THINKING_PREVIEW=0
SQL_QUERY_CACHE_SIZE=0
